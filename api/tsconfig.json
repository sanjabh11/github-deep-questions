{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "..",
    "baseUrl": ".",
    "paths": {
      "@/*": ["../src/*"],
      "shared/*": ["../shared/*"]
    }
  },
  "include": [
    ".",
    "../shared/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
} 